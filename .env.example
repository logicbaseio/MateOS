DATABASE_URL=postgres://postgres:postgres@localhost:5432/mateos

# API server
PORT=8080
MATEOS_AUTH_MODE=local
MATEOS_LOCAL_ADMIN_ID=mateos.local
MATEOS_LOCAL_ADMIN_EMAIL=owner@example.com
MATEOS_LOCAL_ADMIN_FIRST_NAME=MateOS
MATEOS_LOCAL_ADMIN_LAST_NAME=Admin

# Optional generic OIDC auth
# Set MATEOS_AUTH_MODE=oidc to enable this path.
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ISSUER_URL=

# Frontend
BASE_PATH=/

# Optional integrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=
WEBHOOK_BASE_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
ELEVENLABS_API_KEY=
HUME_API_KEY=
HUME_SECRET_KEY=
GROQ_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=
